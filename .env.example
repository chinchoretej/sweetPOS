# ─── Firebase config ───
# (Firebase Console → Project Settings → General → Your apps)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXX

# Optional: enable Firestore offline persistence (default true)
VITE_ENABLE_PERSISTENCE=true

# GitHub Pages base path (must end with slash). Use "/" for custom domain or local dev.
VITE_BASE_PATH=/sweetPOS/

# ─── SaaS roles (v2) ───
# Comma-separated emails. Logging in with any of these is auto-promoted to
# SUPER_ADMIN (the platform owner role). Pick this list carefully.
VITE_SUPER_ADMIN_EMAILS=platform-owner@example.com

# Comma-separated emails treated as legacy v1 admins → bootstrapped as SHOP_OWNER.
# They will be sent through onboarding to create their own shop.
VITE_ADMIN_EMAILS=

# DEV ONLY: pre-shared admin password fallback when Firebase auth is unreachable.
VITE_DEV_ADMIN_PASSWORD=admin123
