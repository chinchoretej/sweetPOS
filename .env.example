# Firebase config (get these from Firebase console > Project settings > Your apps)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXX

# Optional: enable Firestore offline persistence (default true)
VITE_ENABLE_PERSISTENCE=true

# GitHub Pages base path (must end with slash). Use "/" for custom domain or local dev.
VITE_BASE_PATH=/sweetPOS/

# Admin allow-list (comma separated emails). Anyone on this list logging in
# via the admin form gets the "admin" role bootstrapped automatically.
VITE_ADMIN_EMAILS=admin@example.com

# Optional: pre-shared admin password fallback (DEV ONLY)
# Used by the offline/dev login when Firebase auth is unavailable.
VITE_DEV_ADMIN_PASSWORD=admin123
